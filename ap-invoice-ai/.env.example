# ============================================================================
# AP Invoice AI — environment. Copy to .env and fill in. Never commit .env.
# Locked stack: Supabase (Postgres + Storage), Clerk (auth), Inngest (queue).
# ============================================================================

# ---- Database (Supabase Postgres) ----
# Three connection strings. Get host/ref/region from the Supabase dashboard:
# Project Settings -> Database -> Connection string (and Connection pooling).
# REF = your project ref (e.g. abcd1234...), REGION = e.g. aws-0-us-east-1.
#
# Runtime (RLS ENFORCED): app_user via the TRANSACTION pooler (port 6543).
# Custom roles use the dotted username `app_user.REF`. pgbouncer=true is required
# for Prisma over the transaction pooler; connection_limit=1 for serverless.
DATABASE_URL="postgresql://app_user.REF:APP_USER_PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# Migrations / DDL (postgres): SESSION pooler (port 5432) or the direct host.
DIRECT_URL="postgresql://postgres.REF:DB_PASSWORD@REGION.pooler.supabase.com:5432/postgres"
#
# Admin/ops + integration-test seeding (postgres; bypasses RLS for setup).
# Usually identical to DIRECT_URL.
DATABASE_ADMIN_URL="postgresql://postgres.REF:DB_PASSWORD@REGION.pooler.supabase.com:5432/postgres"
#
# Login passwords the bootstrap (npm run db:setup) assigns to the custom roles.
# APP_USER_PASSWORD must match the password embedded in DATABASE_URL above.
APP_USER_PASSWORD="APP_USER_PASSWORD"
APP_WORKER_PASSWORD="choose-a-strong-worker-password"
#
# Integration tests (SEC-3): app_user (RLS) + admin (seeding).
# Paste the SAME values as DATABASE_URL and DATABASE_ADMIN_URL respectively.
INTEGRATION_DATABASE_URL="postgresql://app_user.REF:APP_USER_PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
INTEGRATION_ADMIN_DATABASE_URL="postgresql://postgres.REF:DB_PASSWORD@REGION.pooler.supabase.com:5432/postgres"

# ---- Supabase Storage (private buckets + signed URLs) ----
SUPABASE_URL="https://PROJECT.supabase.co"
# Service-role key — server-side only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DOCUMENTS_BUCKET="ap-invoice-documents"
SUPABASE_RAW_TEXT_BUCKET="ap-invoice-raw-text"
SUPABASE_INBOUND_BUCKET="ap-invoice-inbound"

# ---- Auth (Clerk) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Webhook signing secret for syncing Clerk Organizations/users -> our DB.
CLERK_WEBHOOK_SIGNING_SECRET=""

# ---- Queue (Inngest) ----
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ---- LLM providers (behind gateway; see src/lib/llm) ----
# Only models with zero-retention + signed BAA/DPA may carry invoice traffic (addendum §2.2).
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
LLM_PRIMARY_MODEL="anthropic:claude-sonnet-4-6"
LLM_SECONDARY_MODEL="openai:gpt-4o-2024-08-06"

# ---- AP inbox (SES -> S3 -> SNS -> SQS) ----
AP_INBOX_DOMAIN="in.invoice-ai.com"
AP_INBOX_QUEUE_URL=""
AP_INBOX_DLQ_URL=""

# ---- Limits (addendum §2.6 / §2.7) ----
MAX_FILE_BYTES="26214400"      # 25 MB
MAX_PDF_PAGES="50"
MAX_BATCH_FILES="25"
MAX_DOC_TOKENS="80000"
ORG_DAILY_DOC_QUOTA="1000"
