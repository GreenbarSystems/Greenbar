// AP Invoice AI — data model.
// Mirrors PRD Part I "Database Schema" with the addendum overrides applied:
//   - status columns are enums (addendum §4.3)
//   - RBAC role enum + user_client_access (addendum §1.5)
//   - idempotency indexes (addendum §4.1/§4.2)
//   - api_idempotency_keys (addendum §4.6)
// NOTE: Row-Level Security policies are NOT expressible in schema.prisma.
// They live in prisma/migrations/manual/0001_rls.sql and are applied per migration.
// See src/lib/db/with-org.ts for how `app.current_org_id` is set per transaction.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime: app_user via Supabase transaction pooler (RLS ENFORCED). Our app
  // intentionally connects as the least-privilege role, not as `postgres`.
  url       = env("DATABASE_URL")
  // Migrations (db push / migrate): postgres via the direct/session connection,
  // which has the DDL privileges app_user lacks.
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// Enums (addendum §4.3 / §1.5)
// ----------------------------------------------------------------------------

enum UserRole {
  owner
  admin
  reviewer
  clerk
  viewer
}

enum DocumentStatus {
  received
  processing
  text_extracted
  llm_extracted
  validation_failed
  review_required
  approved
  rejected
  exported
  failed
}

enum InvoiceReviewStatus {
  pending
  needs_review
  approved
  rejected
  exported
  superseded
}

enum EmailMessageStatus {
  received
  processing
  processed
  no_attachments
  unrouted
  failed
}

// ----------------------------------------------------------------------------
// Tenancy & identity
// ----------------------------------------------------------------------------

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users                 User[]
  clients               Client[]
  documents             Document[]
  documentExtractions   DocumentExtraction[]
  emailMessages         EmailMessage[]
  emailAttachments      EmailAttachment[]
  llmRuns               LlmRun[]
  extractedInvoices     ExtractedInvoice[]
  extractedInvoiceLines ExtractedInvoiceLine[]
  vendors               Vendor[]
  vendorMatches         VendorMatch[]
  validationResults     ValidationResult[]
  exports               Export[]
  exportItems           ExportItem[]
  auditEvents           AuditEvent[]
  apiIdempotencyKeys    ApiIdempotencyKey[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  email          String   @unique
  name           String?
  role           UserRole @default(reviewer)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization       @relation(fields: [organizationId], references: [id])
  clientAccess UserClientAccess[]

  @@index([organizationId])
  @@map("users")
}

model Client {
  id                       String   @id @default(uuid()) @db.Uuid
  organizationId           String   @map("organization_id") @db.Uuid
  name                     String
  externalAccountingSystem String?  @map("external_accounting_system")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization       @relation(fields: [organizationId], references: [id])
  access       UserClientAccess[]

  @@index([organizationId])
  @@map("clients")
}

// Firm users scoped to specific clients (addendum §1.5).
model UserClientAccess {
  userId   String   @map("user_id") @db.Uuid
  clientId String   @map("client_id") @db.Uuid
  role     UserRole

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
  @@map("user_client_access")
}

// ----------------------------------------------------------------------------
// AP inbox (addendum §3)
// ----------------------------------------------------------------------------

model EmailMessage {
  id                    String             @id @default(uuid()) @db.Uuid
  organizationId        String             @map("organization_id") @db.Uuid
  clientId              String?            @map("client_id") @db.Uuid
  provider              String
  providerMessageId     String             @map("provider_message_id")
  mailbox               String
  routingAddress        String             @map("routing_address")
  rawMessageStorageKey  String             @map("raw_message_storage_key")
  fromEmail             String?            @map("from_email")
  fromName              String?            @map("from_name")
  subject               String?
  bodyText              String?            @map("body_text")
  receivedAt            DateTime           @map("received_at") @db.Timestamptz(6)
  processedAt           DateTime?          @map("processed_at") @db.Timestamptz(6)
  status                EmailMessageStatus @default(received)
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization      @relation(fields: [organizationId], references: [id])
  attachments  EmailAttachment[]
  documents    Document[]

  @@unique([provider, providerMessageId])
  @@index([mailbox, receivedAt])
  @@map("email_messages")
}

model EmailAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  // Denormalized for RLS coverage (addendum §1.2 / SEC-2). Set from the parent message on insert.
  organizationId  String   @map("organization_id") @db.Uuid
  emailMessageId  String   @map("email_message_id") @db.Uuid
  filename        String
  mimeType        String?  @map("mime_type")
  storageKey      String   @map("storage_key")
  fileSizeBytes   BigInt?  @map("file_size_bytes")
  contentHash     String?  @map("content_hash")
  status          String   @default("received")
  rejectionReason String?  @map("rejection_reason")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  emailMessage EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  documents    Document[]

  @@index([organizationId])
  @@map("email_attachments")
}

// ----------------------------------------------------------------------------
// Documents & processing
// ----------------------------------------------------------------------------

model Document {
  id                String         @id @default(uuid()) @db.Uuid
  organizationId    String         @map("organization_id") @db.Uuid
  clientId          String?        @map("client_id") @db.Uuid
  emailMessageId    String?        @map("email_message_id") @db.Uuid
  emailAttachmentId String?        @map("email_attachment_id") @db.Uuid
  source            String
  originalFilename  String         @map("original_filename")
  mimeType          String?        @map("mime_type")
  storageKey        String         @map("storage_key")
  contentHash       String?        @map("content_hash")
  pageCount         Int?           @map("page_count")
  status            DocumentStatus @default(received)
  receivedAt        DateTime       @default(now()) @map("received_at") @db.Timestamptz(6)
  createdBy         String?        @map("created_by") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  organization     Organization         @relation(fields: [organizationId], references: [id])
  emailMessage     EmailMessage?        @relation(fields: [emailMessageId], references: [id])
  emailAttachment  EmailAttachment?     @relation(fields: [emailAttachmentId], references: [id])
  extractions      DocumentExtraction[]
  llmRuns          LlmRun[]
  extractedInvoices ExtractedInvoice[]

  @@unique([organizationId, contentHash])
  @@index([organizationId, status])
  @@index([clientId, status])
  @@index([contentHash])
  @@map("documents")
}

// Append-only, one row per attempt (addendum §4.1).
model DocumentExtraction {
  id                String   @id @default(uuid()) @db.Uuid
  // Denormalized for RLS coverage (addendum §1.2 / SEC-2). Set from the parent document on insert.
  organizationId    String   @map("organization_id") @db.Uuid
  documentId        String   @map("document_id") @db.Uuid
  method            String
  provider          String?
  rawTextStorageKey String   @map("raw_text_storage_key")
  textLength        Int      @default(0) @map("text_length")
  qualityScore      Decimal? @map("quality_score") @db.Decimal(5, 4)
  averageConfidence Decimal? @map("average_confidence") @db.Decimal(5, 4)
  metadataJson      Json     @default("{}") @map("metadata_json")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([documentId, createdAt(sort: Desc)])
  @@map("document_extractions")
}

// Append-only, one row per attempt (addendum §4.1).
model LlmRun {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  documentId     String?  @map("document_id") @db.Uuid
  provider       String
  model          String
  promptName     String   @map("prompt_name")
  promptVersion  String   @map("prompt_version")
  inputHash      String?  @map("input_hash")
  outputJson     Json?    @map("output_json")
  status         String
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization      Organization       @relation(fields: [organizationId], references: [id])
  document          Document?          @relation(fields: [documentId], references: [id])
  extractedInvoices ExtractedInvoice[]

  @@index([documentId, createdAt(sort: Desc)])
  @@map("llm_runs")
}

// ----------------------------------------------------------------------------
// Extracted invoices (single active row per document — addendum §4.2)
// ----------------------------------------------------------------------------

model ExtractedInvoice {
  id                  String              @id @default(uuid()) @db.Uuid
  organizationId      String              @map("organization_id") @db.Uuid
  clientId            String?             @map("client_id") @db.Uuid
  documentId          String              @map("document_id") @db.Uuid
  llmRunId            String?             @map("llm_run_id") @db.Uuid
  documentType        String              @default("invoice") @map("document_type")
  vendorName          String?             @map("vendor_name")
  vendorAddress       String?             @map("vendor_address")
  remitToName         String?             @map("remit_to_name")
  remitToAddress      String?             @map("remit_to_address")
  invoiceNumber       String?             @map("invoice_number")
  invoiceDate         DateTime?           @map("invoice_date") @db.Date
  dueDate             DateTime?           @map("due_date") @db.Date
  paymentTerms        String?             @map("payment_terms")
  purchaseOrderNumber String?             @map("purchase_order_number")
  currency            String?             @default("USD")
  subtotal            Decimal?            @db.Decimal(14, 2)
  tax                 Decimal?            @db.Decimal(14, 2)
  shipping            Decimal?            @db.Decimal(14, 2)
  discount            Decimal?            @db.Decimal(14, 2)
  total               Decimal?            @db.Decimal(14, 2)
  confidence          String?
  warningsJson        Json                @default("[]") @map("warnings_json")
  reviewStatus        InvoiceReviewStatus @default(pending) @map("review_status")
  reviewedBy          String?             @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?           @map("reviewed_at") @db.Timestamptz(6)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization           @relation(fields: [organizationId], references: [id])
  document     Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  llmRun       LlmRun?                @relation(fields: [llmRunId], references: [id])
  lines        ExtractedInvoiceLine[]
  vendorMatch  VendorMatch?
  exportItems  ExportItem[]

  // Math/duplicate lookup index (PRD "Suggested Indexes").
  @@index([organizationId, vendorName, invoiceNumber])
  @@index([organizationId, reviewStatus])
  // The "one active extraction per document" partial unique index (addendum §4.2)
  // is created in the manual RLS/constraints migration — Prisma cannot express
  // a WHERE-filtered unique index.
  @@map("extracted_invoices")
}

model ExtractedInvoiceLine {
  id                 String   @id @default(uuid()) @db.Uuid
  // Denormalized for RLS coverage (addendum §1.2 / SEC-2). Set from the parent on insert.
  organizationId     String   @map("organization_id") @db.Uuid
  extractedInvoiceId String   @map("extracted_invoice_id") @db.Uuid
  lineNumber         Int?     @map("line_number")
  description        String?
  quantity           Decimal? @db.Decimal(14, 4)
  unitPrice          Decimal? @map("unit_price") @db.Decimal(14, 4)
  amount             Decimal? @db.Decimal(14, 2)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization     Organization     @relation(fields: [organizationId], references: [id])
  extractedInvoice ExtractedInvoice @relation(fields: [extractedInvoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("extracted_invoice_lines")
}

// ----------------------------------------------------------------------------
// Vendors & validation
// ----------------------------------------------------------------------------

model Vendor {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  clientId            String?  @map("client_id") @db.Uuid
  name                String
  normalizedName      String   @map("normalized_name")
  status              String   @default("active")
  defaultPaymentTerms String?  @map("default_payment_terms")
  externalVendorId    String?  @map("external_vendor_id")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization  @relation(fields: [organizationId], references: [id])
  matches      VendorMatch[]

  @@index([organizationId, normalizedName])
  @@map("vendors")
}

model VendorMatch {
  id                 String   @id @default(uuid()) @db.Uuid
  // Denormalized for RLS coverage (addendum §1.2 / SEC-2). Set from the parent invoice on insert.
  organizationId     String   @map("organization_id") @db.Uuid
  extractedInvoiceId String   @unique @map("extracted_invoice_id") @db.Uuid
  vendorId           String?  @map("vendor_id") @db.Uuid
  matchConfidence    String   @map("match_confidence")
  matchScore         Decimal? @map("match_score") @db.Decimal(5, 4)
  candidatesJson     Json     @default("[]") @map("candidates_json")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization     Organization     @relation(fields: [organizationId], references: [id])
  extractedInvoice ExtractedInvoice @relation(fields: [extractedInvoiceId], references: [id], onDelete: Cascade)
  vendor           Vendor?          @relation(fields: [vendorId], references: [id])

  @@index([organizationId])
  @@map("vendor_matches")
}

model ValidationResult {
  id             String   @id @default(uuid()) @db.Uuid
  // Denormalized for RLS coverage (addendum §1.2 / SEC-2). Set from the validated entity on insert.
  organizationId String   @map("organization_id") @db.Uuid
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id") @db.Uuid
  passed         Boolean
  severity       String
  errorsJson     Json     @default("[]") @map("errors_json")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("validation_results")
}

// ----------------------------------------------------------------------------
// Export
// ----------------------------------------------------------------------------

model Export {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  clientId       String?  @map("client_id") @db.Uuid
  exportType     String   @map("export_type")
  storageKey     String?  @map("storage_key")
  status         String   @default("created")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  items        ExportItem[]

  @@map("exports")
}

model ExportItem {
  id                 String   @id @default(uuid()) @db.Uuid
  // Denormalized for RLS coverage (addendum §1.2 / SEC-2). Set from the parent export on insert.
  organizationId     String   @map("organization_id") @db.Uuid
  exportId           String   @map("export_id") @db.Uuid
  extractedInvoiceId String   @map("extracted_invoice_id") @db.Uuid
  status             String   @default("included")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization     Organization     @relation(fields: [organizationId], references: [id])
  export           Export           @relation(fields: [exportId], references: [id], onDelete: Cascade)
  extractedInvoice ExtractedInvoice @relation(fields: [extractedInvoiceId], references: [id])

  @@index([organizationId])
  @@map("export_items")
}

// ----------------------------------------------------------------------------
// Audit & API idempotency
// ----------------------------------------------------------------------------

model AuditEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorType      String   @map("actor_type")
  actorId        String?  @map("actor_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id") @db.Uuid
  beforeJson     Json?    @map("before_json")
  afterJson      Json?    @map("after_json")
  metadataJson   Json     @default("{}") @map("metadata_json")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_events")
}

// API-level idempotency (addendum §4.6).
model ApiIdempotencyKey {
  key            String   @id
  organizationId String   @map("organization_id") @db.Uuid
  requestHash    String   @map("request_hash")
  responseStatus Int      @map("response_status")
  responseBody   Json     @map("response_body")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([createdAt])
  @@map("api_idempotency_keys")
}
